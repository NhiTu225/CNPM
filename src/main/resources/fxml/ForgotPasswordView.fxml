<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane prefWidth="800"
           prefHeight="600"
           style="-fx-background-color: linear-gradient(to bottom right, #1a365d, #2b6cb0);"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.hotelmanagement.controller.ForgotPasswordController">

    <stylesheets>
        <URL value="@/css/style.css" />
    </stylesheets>

    <!-- Background Decor (Circles) -->
    <AnchorPane mouseTransparent="true">
        <!-- Top Left Circle -->
        <Circle centerX="0" centerY="0" radius="160" fill="#c5a8801f"/>
        <Circle centerX="0" centerY="0" radius="100" fill="#c5a88033"/>
        
        <!-- Bottom Right Circle -->
        <Circle AnchorPane.bottomAnchor="-50.0" AnchorPane.rightAnchor="-50.0" radius="180" fill="#c5a8801f"/>
        <Circle AnchorPane.bottomAnchor="-20.0" AnchorPane.rightAnchor="-20.0" radius="120" fill="#c5a88033"/>
        
        <!-- Floating Small Circles -->
        <Circle AnchorPane.topAnchor="80.0" AnchorPane.rightAnchor="120.0" radius="15" fill="transparent" stroke="#ffffff26" strokeWidth="2"/>
        <Circle AnchorPane.bottomAnchor="120.0" AnchorPane.leftAnchor="100.0" radius="25" fill="transparent" stroke="#ffffff1a" strokeWidth="3"/>
    </AnchorPane>

    <!-- Card Quên Mật Khẩu -->
    <VBox alignment="CENTER" spacing="15" styleClass="card" maxWidth="450" prefWidth="450" maxHeight="520">
        <padding>
            <Insets top="30" right="35" bottom="30" left="35"/>
        </padding>

        <!-- Logo/Header -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="KHÔI PHỤC MẬT KHẨU" styleClass="logo" style="-fx-font-size: 24px;"/>
            <Label text="Nhập thông tin xác thực để đặt lại mật khẩu" style="-fx-font-size: 12px; -fx-text-fill: #718096; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Form Fields -->
        <VBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
            <VBox spacing="3">
                <Label text="Địa chỉ Email tài khoản:" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <TextField fx:id="txtEmail" promptText="Nhập email của bạn..." prefHeight="38"/>
            </VBox>
            
            <VBox spacing="3">
                <Label text="Họ và tên đầy đủ đăng ký:" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <TextField fx:id="txtFullName" promptText="Nhập họ và tên đầy đủ..." prefHeight="38"/>
            </VBox>

            <VBox spacing="3">
                <Label text="Mật khẩu mới:" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <PasswordField fx:id="txtNewPassword" promptText="Nhập mật khẩu mới (tối thiểu 6 ký tự)..." prefHeight="38"/>
            </VBox>

            <VBox spacing="3">
                <Label text="Xác nhận mật khẩu mới:" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <PasswordField fx:id="txtConfirmPassword" promptText="Nhập lại mật khẩu mới..." prefHeight="38"/>
            </VBox>
        </VBox>

        <!-- Action Button -->
        <Button text="Đặt Lại Mật Khẩu" onAction="#handleResetPassword" maxWidth="Infinity" prefHeight="45" styleClass="button-primary" style="-fx-margin-top: 10px;"/>
        
        <!-- Go back to Login Link -->
        <Hyperlink text="Quay lại màn hình Đăng nhập" onAction="#backToLogin" style="-fx-text-fill: #2b6cb0; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 5 0 0 0;"/>
    </VBox>
</StackPane>
