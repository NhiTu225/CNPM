<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane prefWidth="800"
           prefHeight="600"
           style="-fx-background-color: linear-gradient(to bottom right, #1a365d, #2b6cb0);"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.hotelmanagement.controller.LoginController">

    <stylesheets>
        <URL value="@/css/style.css" />
    </stylesheets>

    <!-- Background Decor (Circles) -->
    <AnchorPane mouseTransparent="true">
        <!-- Top Left Circle -->
        <Circle centerX="0" centerY="0" radius="160" fill="#c5a8801f"/>
        <Circle centerX="0" centerY="0" radius="100" fill="#c5a88033"/>
        
        <!-- Bottom Right Circle -->
        <Circle AnchorPane.bottomAnchor="-50.0" AnchorPane.rightAnchor="-50.0" radius="180" fill="#c5a8801f"/>
        <Circle AnchorPane.bottomAnchor="-20.0" AnchorPane.rightAnchor="-20.0" radius="120" fill="#c5a88033"/>
        
        <!-- Floating Small Circles -->
        <Circle AnchorPane.topAnchor="80.0" AnchorPane.rightAnchor="120.0" radius="15" fill="transparent" stroke="#ffffff26" strokeWidth="2"/>
        <Circle AnchorPane.bottomAnchor="120.0" AnchorPane.leftAnchor="100.0" radius="25" fill="transparent" stroke="#ffffff1a" strokeWidth="3"/>
    </AnchorPane>

    <!-- Card Đăng Nhập -->
    <VBox alignment="CENTER" spacing="20" styleClass="card" maxWidth="420" prefWidth="420" maxHeight="500">
        <padding>
            <Insets top="40" right="35" bottom="40" left="35"/>
        </padding>

        <!-- Logo thương hiệu -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="GRAND LUXURY" styleClass="logo" style="-fx-font-size: 26px;"/>
            <Label text="Hệ thống Quản lý &amp; Đặt phòng" style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: bold;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="5">
            <Label text="Đăng Nhập Hệ Thống" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a365d;"/>
            <Label text="Vui lòng đăng nhập để tiếp tục sử dụng dịch vụ" style="-fx-font-size: 12px; -fx-text-fill: #a0aec0;"/>
        </VBox>

        <!-- Form Fields -->
        <VBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
            <VBox spacing="5">
                <Label text="Tài khoản / Email:" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <TextField fx:id="txtEmail" promptText="Nhập email của bạn..." prefHeight="40"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Mật khẩu:" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu..." prefHeight="40"/>
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Hyperlink text="Quên mật khẩu?" onAction="#showForgotPasswordView" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-padding: 0;"/>
            </HBox>
        </VBox>

        <!-- Submit Button -->
        <Button text="Xác Thực Đăng Nhập" onAction="#login" maxWidth="Infinity" prefHeight="45" styleClass="button-primary"/>
        
        <!-- Registration Link -->
        <Hyperlink text="Chưa có tài khoản? Đăng ký ngay" onAction="#showRegisterView" style="-fx-text-fill: #2b6cb0; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 5 0 0 0;"/>
    </VBox>
</StackPane>