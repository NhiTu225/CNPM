<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotelmanagement.controller.ReceptionistController"
      prefWidth="1024"
      prefHeight="720"
      spacing="0"
      styleClass="root">

    <stylesheets>
        <URL value="@/css/style.css" />
    </stylesheets>

    <!-- Header Area -->
    <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="20">
        <Label text="GRAND LUXURY" styleClass="logo"/>
        <Label text="Quầy Lễ Tân - Đặt Phòng &amp; Thanh Toán" style="-fx-text-fill: #cbd5e0; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblWelcome" text="Welcome, Lễ tân!" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
        <Button text="Đăng xuất" onAction="#logout" styleClass="button-danger" style="-fx-padding: 6 12;"/>
    </HBox>

    <!-- Main Content Area -->
    <VBox spacing="15" VBox.vgrow="ALWAYS" style="-fx-padding: 20;">
        <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Danh sách đặt phòng của khách hàng" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a365d;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <!-- Control Buttons -->
                <Button text="Làm mới (Refresh)" onAction="#handleRefresh" style="-fx-background-color: #4a5568; -fx-text-fill: white; -fx-padding: 8 16;"/>
                <Button text="Nhận phòng (Check In)" onAction="#handleCheckIn" styleClass="button-success" style="-fx-padding: 8 16;"/>
                <Button text="Trả phòng &amp; Hóa Đơn (Check Out)" onAction="#handleCheckOut" styleClass="button-primary" style="-fx-padding: 8 16;"/>
                <Button text="Hủy đặt phòng" onAction="#handleCancelBooking" styleClass="button-danger" style="-fx-padding: 8 16;"/>
                <Button text="Nhập CSV Phòng" onAction="#importCSV" styleClass="button-primary" style="-fx-background-color: #2b6cb0; -fx-padding: 8 16;"/>
                <Button text="Xuất CSV Phòng" onAction="#exportCSV" styleClass="button-accent" style="-fx-padding: 8 16;"/>
            </HBox>
            
            <TableView fx:id="tblBookings" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colBookingId" text="Mã Đặt" prefWidth="70"/>
                    <TableColumn fx:id="colBookingCustomer" text="Khách hàng (Email)" prefWidth="220"/>
                    <TableColumn fx:id="colBookingRoom" text="Số phòng" prefWidth="100"/>
                    <TableColumn fx:id="colBookingCheckIn" text="Ngày vào" prefWidth="140"/>
                    <TableColumn fx:id="colBookingCheckOut" text="Ngày ra" prefWidth="140"/>
                    <TableColumn fx:id="colBookingTotal" text="Tổng tiền" prefWidth="150"/>
                    <TableColumn fx:id="colBookingStatus" text="Trạng thái" prefWidth="140"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</VBox>
